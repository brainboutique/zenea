APP_NAME=Laravel
APP_ENV=local
APP_KEY=
# Must be false in production. API error responses never expose exception class, file paths, or stack traces.
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database: sqlite (default) or mysql
DB_CONNECTION=sqlite

# SQLite: full path to the database file (default: database/database.sqlite inside the app)
# DB_DATABASE=/path/to/your/database.sqlite

# MySQL / MariaDB (set DB_CONNECTION=mysql to use)
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=
# DB_CHARSET=utf8mb4
# DB_COLLATION=utf8mb4_unicode_ci

SESSION_DRIVER=array
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.example.com
MAIL_PORT=587
# MAIL_ENCRYPTION: tls, ssl, or empty for none (e.g. port 587=tls, 465=ssl)
MAIL_ENCRYPTION=tls
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Mollie (test key for development; use live key in production)
MOLLIE_KEY=test_ySDnH3UcmFcDx3Wn32Bd3SSpkh2R9p
VITE_APP_NAME="${APP_NAME}"

SEVENIO_APIKEY=DEMODEMO

# Data directory (default: ../data relative to Laravel root). Used for entity JSON and Git API.
# The Git remote (origin) is read from the repository in that directory; no .env URL needed.
# DATA_PATH=/absolute/path/to/data

# Optional: Git access token for fetch/push. When set, the token is used to authenticate with
# the data repo's remote (origin); it is not stored in .git/config. Use a Personal Access Token
# (GitLab/GitHub) or OAuth token. GIT_USERNAME defaults to "oauth2" (GitLab); set if needed for GitHub.
# GIT_ACCESS_TOKEN=glpat-xxxxxxxxxxxx
# GIT_USERNAME=oauth2

# Optional: Git author/committer identity used for commits done by the API.
# If set, these are written into the data repo's local git config (user.name, user.email) before commit.
# GIT_USER_NAME=Zenea API
# GIT_USER_EMAIL=api@example.com

# Faceted search: cache TTL in days; facets file is rebuilt when older than this
FACETS_CACHE_TTL_DAYS=1

# Optional: Google OAuth. When both are set, all API routes require a valid Google ID token (Bearer)
# and the user must be listed in /data/.auth.json with "access": true. When unset, no auth is enforced.
# Create /data/.auth.json with e.g. {"user@example.com":{"access":true}}. If the file is missing, any valid token is allowed.
#
# How to obtain Google CLient ID?
# 1: https://console.cloud.google.com/
# 2: Create consent screen
# 3: Register "Web Application": JavaScript Origin your designated host - for example: https://zenea.mycompany.com
#    Redirect URI: https://zenea.mycompany.com/api/v1/auth/callback
# 4: Copy Client ID and Client Secret to your .env file (NOT this sample! You may need to create one!)
# GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=xxx
#
# When running behind a reverse proxy, the OAuth callback URL must use the public host name.
# Set this to the externally visible base URL (e.g. https://zenea.mycompany.com).
# When unset, the host is inferred from the incoming request (X-Forwarded-Host / Host header).
# GOOGLE_REDIRECT_BASE_URL=https://zenea.mycompany.com

# Optional: License key (base64-encoded JSON with "key" and "company" fields).
# When set and valid, the UI displays "Licensed by {company}" instead of the non-commercial notice.
# LICENSE=
